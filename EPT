local function ReconnectActivateInput()
    if ActivateInputConnection then
        ActivateInputConnection:Disconnect()
        ActivateInputConnection = nil
    end
    
    if not currentActivateKey or not UseAllItemsEnabled then return end
    
    ActivateInputConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if not getgenv().EPT_Running or not UseAllItemsEnabled then return end
        if input.KeyCode == currentActivateKey then
            task.spawn(function()
                local n = ActivateAllItems()
                Fluent:Notify({
                    Title    = "⚡ Items Used",
                    Content  = tostring(n) .. " items activated",
                    Duration = 2
                })
            end)
        end
    end)
end

local function ReconnectNoclipInput()
    if NoclipKeybindConnection then
        NoclipKeybindConnection:Disconnect()
        NoclipKeybindConnection = nil
    end
    
    if not currentNoclipKey or not NoclipKeybindEnabled then return end
    
    NoclipKeybindConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if not getgenv().EPT_Running or not NoclipKeybindEnabled then return end
        if input.KeyCode == currentNoclipKey then
            SetNoclip(not NoclipEnabled)
        end
    end)
end

local function ReconnectFlyInput()
    if FlyKeybindConnection then
        FlyKeybindConnection:Disconnect()
        FlyKeybindConnection = nil
    end
    
    if not currentFlyKey or not FlyKeybindEnabled then return end
    
    FlyKeybindConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if not getgenv().EPT_Running or not FlyKeybindEnabled then return end
        if input.KeyCode == currentFlyKey then
            SetFly(not FlyEnabled)
        end
    end)
end

