-- ════════════════════════════════════════════════════════
--  FUNCTION: ACTIVATE ALL ITEMS (keybind callback)
-- ════════════════════════════════════════════════════════
local function ActivateAllItems()
    local character = LocalPlayer.Character
    local backpack  = LocalPlayer:FindFirstChild("Backpack")
    local humanoid  = character and character:FindFirstChildOfClass("Humanoid")
    if not (character and backpack and humanoid) then return 0 end

    local count    = 0
    local allTools = {}

    for _, tool in ipairs(backpack:GetChildren()) do
        if tool:IsA("Tool") then table.insert(allTools, tool) end
    end
    for _, tool in ipairs(character:GetChildren()) do
        if tool:IsA("Tool") then table.insert(allTools, tool) end
    end

    for _, tool in ipairs(allTools) do
        pcall(function()
            humanoid:EquipTool(tool)
            tool:Activate()
            count = count + 1
        end)
    end
    return count
end

-- ════════════════════════════════════════════════════════
--  FUNCTION: GET ALL ITEMS (firetouchinterest)
-- ════════════════════════════════════════════════════════
local function GetAllItems()
    local hrp = LocalPlayer.Character
        and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local function spamTouch(part)
        hrp.CFrame = part.CFrame
        firetouchinterest(hrp, part, 0)
        task.wait(getgenv().EPT_Interval) -- interval from slider
        firetouchinterest(hrp, part, 1)
    end

    for _, part in pairs(Workspace:GetDescendants()) do
        if part:IsA("BasePart") then
            local n = part.Name:lower()
            if n:match("button") or n:match("dropper")
            or n:match("upgrade") or n:match("rebirth") then
                spamTouch(part)
            end
        end
    end

    Fluent:Notify({
        Title    = "📦 Get All Items",
        Content  = "Done! All droppers and buttons touched.",
        Duration = 4
    })
end

