-- ════════════════════════════════════════════════════════
--  FUNCTION: NOCLIP TOGGLE
-- ════════════════════════════════════════════════════════
local function SetNoclip(state)
    NoclipEnabled = state
    
    if NoclipEnabled then
        -- Включаем noclip
        if not NoclipConnection then
            NoclipConnection = RunService.Stepped:Connect(function()
                if NoclipEnabled then
                    local character = LocalPlayer.Character
                    if character then
                        for _, part in pairs(character:GetDescendants()) do
                            if part:IsA("BasePart") and part.CanCollide then
                                part.CanCollide = false
                            end
                        end
                    end
                end
            end)
        end
        
        Fluent:Notify({
            Title    = "🚶‍♂️ Noclip Enabled",
            Content  = "You can now walk through walls",
            Duration = 3
        })
    else
        -- Выключаем noclip
        if NoclipConnection then
            NoclipConnection:Disconnect()
            NoclipConnection = nil
        end
        
        -- Восстанавливаем коллизию
        local character = LocalPlayer.Character
        if character then
            for _, part in pairs(character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end
        end
        
        Fluent:Notify({
            Title    = "🚶‍♂️ Noclip Disabled",
            Content  = "Collision restored",
            Duration = 3
        })
    end
end

-- ════════════════════════════════════════════════════════
--  FUNCTION: ACTIVATE ALL ITEMS
-- ════════════════════════════════════════════════════════
local function ActivateAllItems()
    local character = LocalPlayer.Character
    local backpack  = LocalPlayer:FindFirstChild("Backpack")
    local humanoid  = character and character:FindFirstChildOfClass("Humanoid")
    if not (character and backpack and humanoid) then return 0 end

    local count    = 0
    local allTools = {}

    for _, tool in ipairs(backpack:GetChildren()) do
        if tool:IsA("Tool") then table.insert(allTools, tool) end
    end
    for _, tool in ipairs(character:GetChildren()) do
        if tool:IsA("Tool") then table.insert(allTools, tool) end
    end

    for _, tool in ipairs(allTools) do
        pcall(function()
            humanoid:EquipTool(tool)
            tool:Activate()
            count = count + 1
        end)
    end
    return count
end

-- ════════════════════════════════════════════════════════
--  FUNCTION: GET ALL BUTTONS ONLY
-- ════════════════════════════════════════════════════════
local function GetAllButtons()
    if GetAllItemsRunning then
        Fluent:Notify({
            Title    = "⚠️ Already Running",
            Content  = "Get All Buttons is already active!",
            Duration = 3
        })
        return
    end

    GetAllItemsRunning = true

    task.spawn(function()
        local humanoidRootPart = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not humanoidRootPart then
            GetAllItemsRunning = false
            return
        end

        local function spamTouch(part)
            if part and getgenv().EPT_Running then
                humanoidRootPart.CFrame = part.CFrame
                firetouchinterest(humanoidRootPart, part, 0)
                task.wait(TouchInterval)
                firetouchinterest(humanoidRootPart, part, 1)
            end
        end

        local buttonsFound = 0

        -- Ищем только кнопки (buttons)
        for _, part in pairs(Workspace:GetDescendants()) do
            if not getgenv().EPT_Running then break end
            if part:IsA("BasePart") then
                local partName = part.Name:lower()
                if partName:match("button") then
                    spamTouch(part)
                    buttonsFound = buttonsFound + 1
                    task.wait(TouchInterval)
                end
            end
        end

        GetAllItemsRunning = false

        Fluent:Notify({
            Title    = "🔘 Get All Buttons",
            Content  = "Touched " .. buttonsFound .. " buttons!",
            Duration = 4
        })
    end)
end

