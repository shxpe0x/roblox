local function ActivateAllItems()
    local character = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if not (character and backpack and humanoid) then return 0 end

    local count = 0
    local allTools = {}

    for _, tool in ipairs(backpack:GetChildren()) do
        if tool:IsA("Tool") then table.insert(allTools, tool) end
    end
    for _, tool in ipairs(character:GetChildren()) do
        if tool:IsA("Tool") then table.insert(allTools, tool) end
    end

    for _, tool in ipairs(allTools) do
        pcall(function()
            humanoid:EquipTool(tool)
            tool:Activate()
            count = count + 1
        end)
    end
    return count
end

local function GetAllButtons()
    if GetAllItemsRunning then
        Fluent:Notify({Title = "Already Running", Content = "Get All Buttons is already active!", Duration = 3})
        return
    end

    GetAllItemsRunning = true

    task.spawn(function()
        local humanoidRootPart = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not humanoidRootPart then GetAllItemsRunning = false; return end

        local function spamTouch(part)
            if part and getgenv().EPT_Running then
                humanoidRootPart.CFrame = part.CFrame
                firetouchinterest(humanoidRootPart, part, 0)
                task.wait(0.01)
                firetouchinterest(humanoidRootPart, part, 1)
            end
        end

        local buttonsFound = 0

        for _, part in pairs(Workspace:GetDescendants()) do
            if not getgenv().EPT_Running then break end
            if part:IsA("BasePart") and part.Name:lower():match("button") then
                spamTouch(part)
