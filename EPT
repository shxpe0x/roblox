local function startCFrameFlyLoop() local c = LocalPlayer.Character if not c or not c:FindFirstChild("Head") then return end FLYING = true local H = c.Head H.Anchored = true CFloop = RunService.Heartbeat:Connect(function(d) local h = c:FindFirstChildOfClass("Humanoid") if not h then return end local m = h.MoveDirection * (flySpeed * d) local hc = H.CFrame local cc = workspace.CurrentCamera.CFrame local co = hc:ToObjectSpace(cc).Position cc = cc * CFrame.new(-co.X, -co.Y, -co.Z + 1) local cp = cc.Position local hp = hc.Position local ov = CFrame.new(cp, Vector3.new(hp.X, cp.Y, hp.Z)):VectorToObjectSpace(m) H.CFrame = CFrame.new(hp) * (cc - cp) * CFrame.new(ov) end) end
local function startBodyMoverFlyLoop() local c = LocalPlayer.Character local r = c and c:FindFirstChild("HumanoidRootPart") local h = c and c:FindFirstChildOfClass("Humanoid") if not c or not r or not h then return end FLYING = true flyNoclipConnection = RunService.Heartbeat:Connect(FlyNoclipLoop) task.spawn(function() bodyGyro = Instance.new('BodyGyro', r) bodyGyro.P = 9e4; bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9); bodyGyro.CFrame = r.CFrame bodyVelocity = Instance.new('BodyVelocity', r) bodyVelocity.Velocity = Vector3.new(0,0,0); bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9) h.PlatformStand = true repeat task.wait() local cam = workspace.CurrentCamera local mv = ((cam.CFrame.LookVector * (CONTROL.F + CONTROL.B)) + ((cam.CFrame * CFrame.new((CONTROL.L + CONTROL.R), (CONTROL.Q + CONTROL.E) * 0.2, 0).p) - cam.CFrame.p)) bodyVelocity.Velocity = mv.Magnitude > 0 and mv.Unit * flySpeed or Vector3.new(0,0,0) bodyGyro.CFrame = cam.CFrame until not FLYING or not r.Parent if bodyGyro then bodyGyro:Destroy() end if bodyVelocity then bodyVelocity:Destroy() end if h and h.Parent then h.PlatformStand = false end CONTROL = {F=0, B=0, L=0, R=0, Q=0, E=0} end) end

local function SetFly(state)
    State.FlyEnabled = state local c = LocalPlayer.Character if not c or not c.Parent then return end
    if State.FlyEnabled then for _, p in ipairs(c:GetDescendants()) do if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then p.Transparency = flyTransparency end end if useCFrameFly then for _, p in ipairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end startCFrameFlyLoop() else startBodyMoverFlyLoop() end
    else FLYING = false if CFloop then CFloop:Disconnect(); CFloop = nil end if flyNoclipConnection then flyNoclipConnection:Disconnect(); flyNoclipConnection = nil end if c and c:FindFirstChild("Head") then c.Head.Anchored = false end for _, p in ipairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = true; if p.Name ~= "HumanoidRootPart" then p.Transparency = 0 end end end end
end

