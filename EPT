local function StandOnCollector()
    local hrp = GetHRP() local t = Workspace:FindFirstChild("Tycoons") and Workspace.Tycoons:FindFirstChild(LocalPlayer.Name) if hrp and t then local c = t:FindFirstChild("Auxiliary") and t.Auxiliary:FindFirstChild("Collector") and t.Auxiliary.Collector:FindFirstChild("Collect") if c then SafeTeleport(hrp, c.CFrame + Vector3.new(0, 3, 0)); SmartWait(10) end end
end

local function CheckRebirth()
    local hrp = GetHRP() local t = Workspace:FindFirstChild("Tycoons") and Workspace.Tycoons:FindFirstChild(LocalPlayer.Name)
    if hrp and t then
        local rb = t:FindFirstChild("Auxiliary") and t.Auxiliary:FindFirstChild("Rebirth") and t.Auxiliary.Rebirth:FindFirstChild("Button")
        if rb and rb:IsA("BasePart") then
            SafeTeleport(hrp, rb.CFrame + Vector3.new(0, 3, 0)); task.wait(0.5)
            
            local prompt = rb:FindFirstChildWhichIsA("ProximityPrompt", true)
            if prompt then
                prompt:InputHoldBegin()
                local aborted = SmartWait(10)
                prompt:InputHoldEnd()
                if aborted then return false end
            else
                firetouchinterest(hrp, rb, 0); task.wait(0.05); firetouchinterest(hrp, rb, 1)
            end
            
            State.AutoTycoon = false; State.AutoLoot = false; State.AutoRebirth = false
            pcall(function() Options.AutoTycoonToggle:SetValue(false) end) pcall(function() Options.AutoLootToggle:SetValue(false) end) pcall(function() Options.AutoRebirthToggle:SetValue(false) end)
            Fluent:Notify({Title = "Rebirthed!", Content = "Loops stopped", Duration = 5})
            return true
        end
    end
    return false
end

local function MainFarmLoop()
    if State.isFarmLoopRunning then return end
    State.isFarmLoopRunning = true
    Fluent:Notify({Title = "Farming Started", Duration = 2})
    task.spawn(function()
        while State.AutoTycoon or State.AutoLoot or State.AutoRebirth do
            if not getgenv().EPT_Running then break end
            
            if not GetHRP() then task.wait(2); continue end
            
            if State.AutoRebirth then local r = CheckRebirth() if r then break end end
            
            if State.BossMoneyInterrupt then
                GrabBossMoney()
            else
                if State.AutoTycoon then if HasGreenButtons() then BuyGreenButtons() else StandOnCollector() end end
                if State.AutoLoot then RunLootPhase() end
            end
            
            task.wait(1.5)
        end
        State.isFarmLoopRunning = false
        Fluent:Notify({Title = "Farming Stopped", Duration = 2})
    end)
end

