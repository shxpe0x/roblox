local function ScanAllPlayers() local r = {} for _, p in ipairs(Players:GetPlayers()) do local d = {Player=p, DisplayName=p.Name, Team=GetPlayerTeam(p), Pads={}} for _, pt in ipairs(PadTypes) do local e, pi = CheckPadExists(p.Name, pt.Path) if e then table.insert(d.Pads, {Type=pt.Name, Instance=pi}) end end if #d.Pads>0 then table.insert(r, d) end end return r end
