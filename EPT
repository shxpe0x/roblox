-- ════════════════════════════════════════════════════════
--  ФУНКЦИЯ ДЛЯ ПЕРЕПОДКЛЮЧЕНИЯ ИНПУТА
-- ════════════════════════════════════════════════════════
local function ReconnectInput()
    -- Отключаем старое подключение
    if InputConnection then
        InputConnection:Disconnect()
        InputConnection = nil
    end
    
    -- Если ключ не установлен — не подключаем
    if not currentKey then return end
    
    -- Создаём новое подключение
    InputConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if not getgenv().EPT_Running then return end
        if input.KeyCode == currentKey then
            task.spawn(function()
                local n = ActivateAllItems()
                Fluent:Notify({
                    Title    = "⚡ Activated!",
                    Content  = "Items used: " .. n,
                    Duration = 2
                })
            end)
        end
    end)
end

