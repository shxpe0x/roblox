-- ════════════════════════════════════════════════════════
local function GetPlayerTeam(player)
    if player.Team then
        return player.Team.Name
    end
    return "No Team"
end

local function CheckPadExists(playerName, padPath)
    local tycoons = Workspace:FindFirstChild("Tycoons")
    if not tycoons then return false, nil end
    
    local playerTycoon = tycoons:FindFirstChild(playerName)
    if not playerTycoon then return false, nil end
    
    local assets = playerTycoon:FindFirstChild("Assets")
    if not assets then return false, nil end
    
    local pathParts = string.split(padPath, ".")
    local current = assets
    
    for _, part in ipairs(pathParts) do
        current = current:FindFirstChild(part)
        if not current then return false, nil end
    end
    
    if current:IsA("BasePart") then
        return true, current
    end
    
    return false, nil
end

local function ScanAllPlayers()
    local results = {}
    
    for _, player in ipairs(Players:GetPlayers()) do
        local playerData = {
            Player = player,
            DisplayName = player.Name,
            Team = GetPlayerTeam(player),
            Pads = {}
        }
        
        for _, padType in ipairs(PadTypes) do
            local exists, padInstance = CheckPadExists(player.Name, padType.Path)
            if exists then
                table.insert(playerData.Pads, {
                    Type = padType.Name,
                    Instance = padInstance,
                    Path = padType.Path
                })
            end
        end
        
        if #playerData.Pads > 0 then
            table.insert(results, playerData)
        end
    end
    
    return results
end

local function TeleportToPad(padInstance)
    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    
    if hrp and padInstance then
        hrp.CFrame = padInstance.CFrame + Vector3.new(0, 3, 0)
        return true
    end
    return false
end

-- ════════════════════════════════════════════════════════
--  TREASURE TELEPORT FUNCTIONS
-- ════════════════════════════════════════════════════════
local function ScanAndTeleportToTreasure()
    local treasureFolder = Workspace:FindFirstChild("Treasure")
    if not treasureFolder then
        Fluent:Notify({
            Title    = "❌ Not Found",
            Content  = "Treasure folder doesn't exist",
            Duration = 3
        })
        return
    end
    
    local chestsFolder = treasureFolder:FindFirstChild("Chests")
    if not chestsFolder then
        Fluent:Notify({
            Title    = "❌ Not Found",
            Content  = "Chests folder doesn't exist",
            Duration = 3
        })
        return
    end
    
    local availableTreasures = {}
    
    local namedChest = chestsFolder:FindFirstChild("Chest")
    if namedChest and namedChest:IsA("BasePart") then
        table.insert(availableTreasures, {Name = "Chest", Instance = namedChest})
    end
    
    local children = chestsFolder:GetChildren()
    for i = 2, 5 do
        if children[i] and children[i]:IsA("BasePart") then
            table.insert(availableTreasures, {Name = "Chest " .. i, Instance = children[i]})
        end
    end
    
    if #availableTreasures == 0 then
        Fluent:Notify({
            Title    = "❌ No Treasures",
            Content  = "All chests collected!",
            Duration = 3
        })
        return
    end
    
    local randomTreasure = availableTreasures[math.random(1, #availableTreasures)]
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    
    if hrp and randomTreasure.Instance then
        hrp.CFrame = randomTreasure.Instance.CFrame + Vector3.new(0, 5, 0)
        Fluent:Notify({
            Title    = "💎 Teleported",
            Content  = randomTreasure.Name .. " (" .. #availableTreasures .. " available)",
            Duration = 3
        })
    end
end

-- ════════════════════════════════════════════════════════
--  BASE TELEPORT FUNCTIONS
-- ════════════════════════════════════════════════════════
local function ScanBases()
    AvailableBases = {}
    
    local tycoons = Workspace:FindFirstChild("Tycoons")
    if not tycoons then return end
    
    for _, obj in ipairs(tycoons:GetChildren()) do
        if obj.Name == "Claim" or not obj:IsA("Model") then continue end
        
        local auxiliary = obj:FindFirstChild("Auxiliary")
        if auxiliary then
            local floor = auxiliary:FindFirstChild("Floor")
            if floor then
                local part = floor:FindFirstChild("Part")
                if part and part:IsA("BasePart") then
                    table.insert(AvailableBases, {
                        Name = obj.Name,
                        Instance = part
                    })
                end
            end
        end
    end
end

