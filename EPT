-- Unload

local function Unload()
    getgenv().EPT_Running = false
    getgenv().EPT_Loaded = false

    if NoclipEnabled then SetNoclip(false) end
    if FlyEnabled then SetFly(false) end

    if ActivateInputConnection then ActivateInputConnection:Disconnect(); ActivateInputConnection = nil end
    if TeleportInputConnection then TeleportInputConnection:Disconnect(); TeleportInputConnection = nil end
    if NoclipKeybindConnection then NoclipKeybindConnection:Disconnect(); NoclipKeybindConnection = nil end
    if FlyKeybindConnection then FlyKeybindConnection:Disconnect(); FlyKeybindConnection = nil end

    pcall(function() Fluent.Unloaded = true end)
    pcall(function() Window:Destroy() end)
end

getgenv().EPT_Unload = Unload

LocalPlayer.CharacterAdded:Connect(function()
    if CFloop then CFloop:Disconnect(); CFloop = nil end
    if flyNoclipConnection then flyNoclipConnection:Disconnect(); flyNoclipConnection = nil end
    FLYING = false
    if FlyEnabled then task.wait(1); SetFly(true) end
end)

