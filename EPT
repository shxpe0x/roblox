        Description = "Delay between firetouchinterest calls (seconds)",
        Default     = 0.01,
        Min         = 0.00,
        Max         = 1.00,
        Rounding    = 2,
        Callback    = function(Value)
            TouchInterval = Value -- обновляем локальную переменную
        end
    })

    -- ── ACTIVATION KEYBIND ────────────────────────────────
    Tabs.Main:AddKeybind("ActivateKey", {
        Title   = "Activation Keybind",
        Mode    = "Always",
        Default = "None", -- изменено на None

        Callback = function() end,

        ChangedCallback = function(New)
            -- Парсим новый ключ
            local newKeyStr = tostring(New):match("%.(%w+)$") or tostring(New)
            
            if newKeyStr == "None" or newKeyStr == "" then
                currentKey = nil
                ReconnectInput() -- отключит подключение
                Fluent:Notify({
                    Title    = "⌨️ Keybind disabled",
                    Content  = "No key assigned",
                    Duration = 3
                })
            else
                pcall(function()
                    currentKey = Enum.KeyCode[newKeyStr]
                    ReconnectInput() -- переподключаем с новым ключом
                    Fluent:Notify({
                        Title    = "⌨️ Keybind changed",
                        Content  = "New key: " .. newKeyStr,
                        Duration = 3
                    })
                end)
            end
        end
    })

    -- ── UNLOAD BUTTON ─────────────────────────────────────
    Tabs.Main:AddButton({
        Title       = "Unload Script",
        Description = "Remove GUI and disconnect all listeners",
        Callback    = function()
            Window:Dialog({
                Title   = "Unload Script",
                Content = "Are you sure? Keybind and GUI will be fully removed.",
                Buttons = {
                    {
                        Title    = "Unload",
                        Callback = function()
                            getgenv().EPT_Unload()
                        end
                    },
                    {
                        Title    = "Cancel",
                        Callback = function() end
                    }
                }
            })
        end
    })
end

