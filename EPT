local function ShouldAbort()
    return not getgenv().EPT_Running or not (State.AutoTycoon or State.AutoLoot or State.AutoRebirth)
end

local function GetHRP()
    local char = LocalPlayer.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hrp and hum and hum.Health > 0 then return hrp end
    end
    return nil
end

local function HumanizeWait(min, max)
    task.wait(math.random() * (max - min) + min)
end

local function SafeTeleport(hrp, targetCFrame)
    if not hrp then return end
    local now = tick()
    if now - lastTeleportTick < 0.2 then task.wait(0.2) end
    lastTeleportTick = tick()
    
    local wasAnchored = hrp.Anchored
    pcall(function()
        hrp.Anchored = true
        hrp.CFrame = targetCFrame
    end)
    task.wait(0.05)
    pcall(function()
        if not wasAnchored then hrp.Anchored = false end
        local humanoid = hrp.Parent and hrp.Parent:FindFirstChildOfClass("Humanoid")
        if humanoid then humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end
    end)
end

local function SmartWait(duration)
    local steps = math.floor(duration / 0.1)
    for i = 1, steps do
        if State.BossMoneyInterrupt or ShouldAbort() then return true end
        task.wait(0.1)
    end
    return false
end

