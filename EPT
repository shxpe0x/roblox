local function DeleteHeldItem()
    local char = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not char then return end
    local heldTool = nil
    for _, item in ipairs(char:GetChildren()) do if item:IsA("Tool") then heldTool = item; break end end
    if heldTool then
        local toolName = heldTool.Name; heldTool:Destroy()
        if backpack then for _, item in ipairs(backpack:GetChildren()) do if item:IsA("Tool") and item.Name == toolName then item:Destroy() end end end
