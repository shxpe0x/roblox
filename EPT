local function Unload()
    getgenv().EPT_Running = false; getgenv().EPT_Loaded = false
    State.AutoTycoon = false; State.AutoLoot = false; State.AutoRebirth = false
    if State.NoclipEnabled then SetNoclip(false) end
    if State.FlyEnabled then SetFly(false) end
    SetAntiAFK(false)
    if ActivateInputConnection then ActivateInputConnection:Disconnect() end
    if TeleportInputConnection then TeleportInputConnection:Disconnect() end
    if NoclipKeybindConnection then NoclipKeybindConnection:Disconnect() end
    if FlyKeybindConnection then FlyKeybindConnection:Disconnect() end
    pcall(function() Fluent.Unloaded = true end); pcall(function() Window:Destroy() end)
end
getgenv().EPT_Unload = Unload

