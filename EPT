-- ════════════════════════════════════════════════════════
--  UNLOAD FUNCTION
-- ════════════════════════════════════════════════════════
local function Unload()
    -- 1. Kill the flag — stops any future key presses
    getgenv().EPT_Running = false
    getgenv().EPT_Loaded  = false

    -- 2. Disconnect the input manually — KEY STOPS WORKING HERE
    pcall(function()
        InputConnection:Disconnect()
    end)

    -- 3. Tell Fluent to stop internal tasks
    pcall(function()
        Fluent.Unloaded = true
    end)

    -- 4. Destroy the window (removes GUI visually)
    pcall(function()
        Window:Destroy()
    end)

    print("[EPT] Unloaded successfully. Keybind disconnected.")
end

getgenv().EPT_Unload = Unload

