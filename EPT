local function GrabBossMoney()
    local hrp = GetHRP() if not hrp then return end
    local moneyParts = {}
    pcall(function() for _, v in next, getnilinstances() do if v.ClassName == "Part" and (v.Name == "Dollar" or v.Name == "Money" or v.Name == "Cash") then table.insert(moneyParts, v) end end end)
    for _, v in ipairs(Workspace:GetDescendants()) do if v:IsA("BasePart") and (v.Name == "Dollar" or v.Name == "Money" or v.Name == "Cash") then table.insert(moneyParts, v) end end
    for _, part in ipairs(moneyParts) do
        if ShouldAbort() then return end
        if part and part.Parent then SafeTeleport(hrp, part.CFrame); task.wait(0.05) end
    end
    State.BossMoneyInterrupt = false
end

local function RunLootPhase()
    local hrp = GetHRP() if not hrp then return end
    GrabBossMoney()
    for _, obj in ipairs(Workspace:GetChildren()) do
        if State.BossMoneyInterrupt or ShouldAbort() then return end
        if obj.Name == "BalloonCrate" then
            local target = obj:IsA("Model") and (obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")) or obj
            if target then 
                SafeTeleport(hrp, target.CFrame + Vector3.new(0, 3, 0)); HumanizeWait(0.1, 0.2)
                for i = 1, 33 do
                    if State.BossMoneyInterrupt or ShouldAbort() then return end
                    pcall(function() local p = obj:FindFirstChildWhichIsA("ProximityPrompt", true) if p then p:InputHoldBegin() task.wait(0.05) p:InputHoldEnd() end end)
                    task.wait(0.05)
                end
            end
        end
    end
    local tf = Workspace:FindFirstChild("Treasure") if tf then local cf = tf:FindFirstChild("Chests") if cf then for _, ch in ipairs(cf:GetChildren()) do if State.BossMoneyInterrupt or ShouldAbort() then return end if ch:IsA("BasePart") then SafeTeleport(hrp, ch.CFrame + Vector3.new(0, 3, 0)); HumanizeWait(0.1, 0.2) for i = 1, 33 do if State.BossMoneyInterrupt or ShouldAbort() then return end pcall(function() local p = ch:FindFirstChildWhichIsA("ProximityPrompt", true) if p then p:InputHoldBegin() task.wait(0.05) p:InputHoldEnd() else firetouchinterest(hrp, ch, 0) task.wait(0.05) firetouchinterest(hrp, ch, 1) end end) task.wait(0.05) end end end end end
end

