                for _, v in pairs(Site.data) do
                    if tonumber(v.maxPlayers) > tonumber(v.playing) then
                        local ID = tostring(v.id); local isVisited = false
                        for _, vis in ipairs(visitedServers) do if vis == ID then isVisited = true; break end end
                        if not isVisited then table.insert(visitedServers, ID); TeleportService:TeleportToPlaceInstance(PlaceID, ID, LocalPlayer); isHopping = false; break end
                    end
                end
            end)
