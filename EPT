-- ════════════════════════════════════════════════════════
--  FUNCTION: GET ALL ITEMS (УЛУЧШЕННАЯ ВЕРСИЯ)
-- ════════════════════════════════════════════════════════
local function GetAllItems()
    if GetAllItemsRunning then
        Fluent:Notify({
            Title    = "⚠️ Already Running",
            Content  = "Get All Items is already active!",
            Duration = 3
        })
        return
    end

    GetAllItemsRunning = true

    task.spawn(function()
        local humanoidRootPart = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not humanoidRootPart then
            GetAllItemsRunning = false
            return
        end

        local function spamTouch(part)
            if part and getgenv().EPT_Running then
                humanoidRootPart.CFrame = part.CFrame
                firetouchinterest(humanoidRootPart, part, 0)
                task.wait(TouchInterval)
                firetouchinterest(humanoidRootPart, part, 1)
            end
        end

        local function cloneAndCollect(parent)
            for _, obj in pairs(parent:GetDescendants()) do
                if not getgenv().EPT_Running then break end
                if obj:IsA("BasePart") and (obj.Name:lower():match("cash") or obj.Name:lower():match("money") or obj.Name:lower():match("drop")) then
                    pcall(function()
                        local clone = obj:Clone()
                        clone.Position = humanoidRootPart.Position
                        clone.Parent = Workspace
                        clone.Anchored = false
                        spamTouch(clone)
                        clone:Destroy()
                        task.wait(TouchInterval)
                    end)
                end
            end
        end

        local function exploitInteractables()
            for _, part in pairs(Workspace:GetDescendants()) do
                if not getgenv().EPT_Running then break end
                if part:IsA("BasePart") then
                    local isTarget = part.Name:lower():match("button") or 
                                   part.Name:lower():match("dropper") or 
                                   part.Name:lower():match("upgrade") or 
                                   part.Name:lower():match("rebirth")
                    if isTarget then
                        spamTouch(part)
                    end
                end
            end
        end

        -- Основной цикл
        cloneAndCollect(Workspace)
        exploitInteractables()

        GetAllItemsRunning = false

        Fluent:Notify({
            Title    = "📦 Get All Items",
            Content  = "Done! All items collected.",
            Duration = 4
        })
    end)
end

