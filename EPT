-- ════════════════════════════════════════════════════════
--  MANUAL INPUT CONNECTION (bulletproof unload)
-- ════════════════════════════════════════════════════════
-- We keep our OWN connection reference so we can
-- Disconnect() it manually on unload — 100% guaranteed.
local InputConnection
local currentKey = Enum.KeyCode.F -- default key

InputConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if not getgenv().EPT_Running then return end
    if input.KeyCode == currentKey then
        task.spawn(function()
            local n = ActivateAllItems()
            Fluent:Notify({
                Title    = "⚡ Activated!",
                Content  = "Items used: " .. n,
                Duration = 2
            })
        end)
    end
end)

-- ════════════════════════════════════════════════════════
