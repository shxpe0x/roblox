local function GetPlayerTeam(player)
    return player.Team and player.Team.Name or "No Team"
end

local function CheckPadExists(playerName, padPath)
    local tycoons = Workspace:FindFirstChild("Tycoons")
    if not tycoons then return false, nil end
    
    local playerTycoon = tycoons:FindFirstChild(playerName)
    if not playerTycoon then return false, nil end
    
    local assets = playerTycoon:FindFirstChild("Assets")
    if not assets then return false, nil end
    
    local current = assets
    for _, part in ipairs(string.split(padPath, ".")) do
        current = current:FindFirstChild(part)
        if not current then return false, nil end
    end
    
    if current:IsA("BasePart") then return true, current end
    return false, nil
end

local function ScanAllPlayers()
    local results = {}
    for _, player in ipairs(Players:GetPlayers()) do
        local playerData = {
            Player = player,
            DisplayName = player.Name,
            Team = GetPlayerTeam(player),
            Pads = {}
        }
        
        for _, padType in ipairs(PadTypes) do
            local exists, padInstance = CheckPadExists(player.Name, padType.Path)
            if exists then
                table.insert(playerData.Pads, {
                    Type = padType.Name,
                    Instance = padInstance,
                    Path = padType.Path
                })
            end
        end
        
        if #playerData.Pads > 0 then table.insert(results, playerData) end
    end
    return results
end

