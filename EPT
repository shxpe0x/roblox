    -- ── TOUCH INTERVAL SLIDER ─────────────────────────────
    Tabs.Main:AddSlider("TouchInterval", {
        Title       = "Touch Interval",
        Description = "Delay between firetouchinterest calls (seconds)",
        Default     = 0.01,
        Min         = 0.00,
        Max         = 1.00,
        Rounding    = 2,
        Callback    = function(Value)
            getgenv().EPT_Interval = Value
        end
    })

    -- ── ACTIVATION KEYBIND ────────────────────────────────
    -- Fluent's AddKeybind handles the visual button in GUI.
    -- Our manual InputConnection (above) does the real work.
    -- ChangedCallback keeps currentKey in sync.
    Tabs.Main:AddKeybind("ActivateKey", {
        Title   = "Activation Keybind",
        Mode    = "Always",
        Default = "F",

        Callback = function() end, -- handled by InputConnection

        ChangedCallback = function(New)
            -- Sync the manual connection to the new key
            pcall(function()
                currentKey = Enum.KeyCode[tostring(New):match("%.(%w+)$") or tostring(New)]
            end)
            Fluent:Notify({
                Title    = "⌨️ Keybind changed",
                Content  = "New key: " .. tostring(New),
                Duration = 3
            })
        end
    })

    -- ── UNLOAD BUTTON ─────────────────────────────────────
    Tabs.Main:AddButton({
        Title       = "Unload Script",
        Description = "Remove GUI and disconnect all listeners",
        Callback    = function()
            Window:Dialog({
