local function ScanBases() AvailableBases = {}; local t = Workspace:FindFirstChild("Tycoons") if not t then return end for _, o in ipairs(t:GetChildren()) do if o.Name=="Claim" or not o:IsA("Model") then continue end local a = o:FindFirstChild("Auxiliary") if a then local f = a:FindFirstChild("Floor") if f then local p = f:FindFirstChild("Part") if p and p:IsA("BasePart") then table.insert(AvailableBases, {Name=o.Name, Instance=p}) end end end end end
