local function CheckRebirth()
    local hrp = GetHRP()
    local tycoon = Workspace:FindFirstChild("Tycoons") and Workspace.Tycoons:FindFirstChild(LocalPlayer.Name)
    if hrp and tycoon then
        local rebirthBtn = tycoon:FindFirstChild("Auxiliary") and tycoon.Auxiliary:FindFirstChild("Rebirth") and tycoon.Auxiliary.Rebirth:FindFirstChild("Button")
        if rebirthBtn and rebirthBtn:IsA("BasePart") then
            SafeTeleport(hrp, rebirthBtn.CFrame + Vector3.new(0, 3, 0))
            task.wait(0.5)
            pcall(function()
                local prompt = rebirthBtn:FindFirstChildWhichIsA("ProximityPrompt", true)
                if prompt then prompt:InputHoldBegin() task.wait(10) prompt:InputHoldEnd()
                else firetouchinterest(hrp, rebirthBtn, 0) task.wait(0.05) firetouchinterest(hrp, rebirthBtn, 1) end
            end)
            State.AutoTycoon = false; State.AutoLoot = false; State.AutoRebirth = false
            pcall(function() Options.AutoTycoonToggle:SetValue(false) end)
            pcall(function() Options.AutoLootToggle:SetValue(false) end)
            pcall(function() Options.AutoRebirthToggle:SetValue(false) end)
            Fluent:Notify({Title = "Rebirthed!", Content = "Loops stopped", Duration = 5})
            return true
        end
    end
    return false
end

local function MainFarmLoop()
    if State.isFarmLoopRunning then return end
    State.isFarmLoopRunning = true
    Fluent:Notify({Title = "Farming Started", Duration = 2})
    task.spawn(function()
        while State.AutoTycoon or State.AutoLoot or State.AutoRebirth do
            if not getgenv().EPT_Running then break end
            
            if not GetHRP() then
                task.wait(2)
                continue
            end
            
            if State.AutoRebirth then
                local rebirthed = CheckRebirth()
                if rebirthed then break end
            end
            
            if State.BossMoneyInterrupt then
                GrabBossMoney()
            else
                if State.AutoTycoon then
                    if HasGreenButtons() then
                        BuyGreenButtons()
                    else
                        StandOnCollector()
                    end
                end
                
                if State.AutoLoot then
                    RunLootPhase()
                end
            end
            
            task.wait(1.5)
        end
        State.isFarmLoopRunning = false
        Fluent:Notify({Title = "Farming Stopped", Duration = 2})
    end)
end

