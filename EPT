local function UpdateScanDisplay() local t = "Found " .. #CurrentScanResults .. " player(s):\n\n" for _, d in ipairs(CurrentScanResults) do t = t .. "• " .. d.DisplayName .. " [" .. d.Team .. "] — " .. #d.Pads .. " pad(s)\n" end if #CurrentScanResults == 0 then t = "No pads" end ScanResultsParagraph:SetDesc(t) local names = {} for _, d in ipairs(CurrentScanResults) do table.insert(names, d.DisplayName .. " [" .. d.Team .. "]") end Options.PlayerSelect:SetValues(#names > 0 and names or {"Scan first"}) end
Tabs.Teleports:AddButton({Title = "Scan Pads", Callback = function() CurrentScanResults = ScanAllPlayers(); UpdateScanDisplay(); Fluent:Notify({Title = "Scan Done", Duration = 2}) end})
Tabs.Teleports:AddDropdown("PlayerSelect", {Title = "Select Player", Values = {"Scan first"}, Multi = false, Default = 1, Callback = function(V) if not V or V == "Scan first" then return end for _, d in ipairs(CurrentScanResults) do if V == d.DisplayName .. " [" .. d.Team .. "]" then SelectedPlayer = d local names = {} for _, p in ipairs(d.Pads) do table.insert(names, p.Type) end if #names > 0 then Options.PadSelect:SetValues(names); Options.PadSelect:SetValue(names[1]); SelectedPad = d.Pads[1] end break end end end})
Tabs.Teleports:AddDropdown("PadSelect", {Title = "Select Pad", Values = {"Select player"}, Multi = false, Default = 1, Callback = function(V) if not V or not SelectedPlayer then return end for _, p in ipairs(SelectedPlayer.Pads) do if p.Type == V then SelectedPad = p; break end end end})
