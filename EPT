--  UNLOAD FUNCTION
-- ════════════════════════════════════════════════════════
local function Unload()
    getgenv().EPT_Running = false
    getgenv().EPT_Loaded  = false

    if ActivateInputConnection then
        ActivateInputConnection:Disconnect()
        ActivateInputConnection = nil
    end

    if TeleportInputConnection then
        TeleportInputConnection:Disconnect()
        TeleportInputConnection = nil
    end

    pcall(function()
        Fluent.Unloaded = true
    end)

    pcall(function()
        Window:Destroy()
    end)

    print("[EPT] Unloaded successfully. All keybinds disconnected.")
end

getgenv().EPT_Unload = Unload

