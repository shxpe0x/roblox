local function ScanAndTeleportToTreasure()
    local treasureFolder = Workspace:FindFirstChild("Treasure")
    if not treasureFolder then
        Fluent:Notify({Title = "Not Found", Content = "Treasure folder doesn't exist", Duration = 3})
        return
    end
    
    local chestsFolder = treasureFolder:FindFirstChild("Chests")
    if not chestsFolder then
        Fluent:Notify({Title = "Not Found", Content = "Chests folder doesn't exist", Duration = 3})
        return
    end
    
    local availableTreasures = {}
    
    local namedChest = chestsFolder:FindFirstChild("Chest")
    if namedChest and namedChest:IsA("BasePart") then
        table.insert(availableTreasures, {Name = "Chest", Instance = namedChest})
    end
    
    local children = chestsFolder:GetChildren()
    for i = 2, 5 do
        if children[i] and children[i]:IsA("BasePart") then
            table.insert(availableTreasures, {Name = "Chest " .. i, Instance = children[i]})
        end
    end
    
    if #availableTreasures == 0 then
        Fluent:Notify({Title = "No Treasures", Content = "All chests collected!", Duration = 3})
        return
    end
    
    local randomTreasure = availableTreasures[math.random(1, #availableTreasures)]
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    
    if hrp and randomTreasure.Instance then
        hrp.CFrame = randomTreasure.Instance.CFrame + Vector3.new(0, 5, 0)
        Fluent:Notify({Title = "Teleported", Content = randomTreasure.Name .. " (" .. #availableTreasures .. " available)", Duration = 3})
    end
end

local function ScanBases()
    AvailableBases = {}
    local tycoons = Workspace:FindFirstChild("Tycoons")
    if not tycoons then return end
    
    for _, obj in ipairs(tycoons:GetChildren()) do
        if obj.Name == "Claim" or not obj:IsA("Model") then continue end
        local auxiliary = obj:FindFirstChild("Auxiliary")
        if auxiliary then
            local floor = auxiliary:FindFirstChild("Floor")
            if floor then
                local part = floor:FindFirstChild("Part")
                if part and part:IsA("BasePart") then
                    table.insert(AvailableBases, {Name = obj.Name, Instance = part})
                end
            end
        end
    end
end

local function TeleportToLocation(path, offset)
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local success, target = pcall(function()
        return loadstring("return " .. path)()
    end)
    
    if success and target and target:IsA("BasePart") then
        hrp.CFrame = target.CFrame + (offset or Vector3.new(0, 5, 0))
        return true
    end
    return false
end

