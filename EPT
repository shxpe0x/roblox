local function GetPlayerTeam(p) return p.Team and p.Team.Name or "No Team" end
local function CheckPadExists(pn, pp)
    local t = Workspace:FindFirstChild("Tycoons"); if not t then return false, nil end
    local pt = t:FindFirstChild(pn); if not pt then return false, nil end
    local a = pt:FindFirstChild("Assets"); if not a then return false, nil end
    local current = a
    for _, p in ipairs(string.split(pp, ".")) do current = current:FindFirstChild(p); if not current then return false, nil end end
    if current:IsA("BasePart") then return true, current end
    return false, nil
end
local function ScanAllPlayers()
    local results = {}
    for _, player in ipairs(Players:GetPlayers()) do
        local playerData = {Player = player, DisplayName = player.Name, Team = GetPlayerTeam(player), Pads = {}}
        for _, pt in ipairs(PadTypes) do local exists, instance = CheckPadExists(player.Name, pt.Path) if exists then table.insert(playerData.Pads, {Type = pt.Name, Instance = instance}) end end
        if #playerData.Pads > 0 then table.insert(results, playerData) end
    end
    return results
end
