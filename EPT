    AvailableBases = {}; local t = Workspace:FindFirstChild("Tycoons") if not t then return end
    for _, obj in ipairs(t:GetChildren()) do if obj.Name == "Claim" or not obj:IsA("Model") then continue end local aux = obj:FindFirstChild("Auxiliary") if aux then local floor = aux:FindFirstChild("Floor") if floor then local part = floor:FindFirstChild("Part") if part and part:IsA("BasePart") then table.insert(AvailableBases, {Name = obj.Name, Instance = part}) end end end end
end
